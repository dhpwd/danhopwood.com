---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div
  class:list={[
    "newsletter-signup",
    {
      "not-prose mt-8 mb-8 rounded-lg border border-border p-6 dark:border-accent":
        !compact,
    },
  ]}
>
  <h2
    class:list={[compact ? "text-lg font-semibold" : "text-xl font-semibold"]}
  >
    Build Notes
  </h2>
  <p class="mt-1 text-sm opacity-80">
    Every Thursday morning. Discoveries from building a company entirely with AI
    agents. Patterns, tools and decisions that worked – no fluff.
  </p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/dhpwd"
    method="post"
    class="mt-3 flex gap-2"
  >
    <input type="hidden" name="tag" value="website" />
    <input type="hidden" name="embed" value="1" />
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="flex-1 rounded border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:opacity-50 focus:border-accent focus:outline-none"
    />
    <button
      type="submit"
      class="rounded bg-accent px-4 py-2 text-sm font-medium text-white hover:opacity-90 disabled:opacity-50"
    >
      Subscribe
    </button>
  </form>
  <p class="mt-2 hidden text-sm" data-newsletter-msg></p>
</div>

<script>
  function trackSignup() {
    if (typeof window.plausible === "function") {
      window.plausible("Newsletter Signup");
    }
  }

  function initNewsletterForms() {
    document
      .querySelectorAll<HTMLFormElement>(".newsletter-signup form")
      .forEach(form => {
        if (form.dataset.initialized) return;
        form.dataset.initialized = "true";

        form.addEventListener("submit", async e => {
          e.preventDefault();
          const btn = form.querySelector("button")!;
          const msg = form.parentElement!.querySelector(
            "[data-newsletter-msg]"
          )!;
          const email = form.querySelector<HTMLInputElement>("[name=email]")!;

          btn.setAttribute("disabled", "");
          btn.textContent = "Subscribing…";
          msg.classList.add("hidden");

          function showSuccess() {
            msg.textContent = "You're in – check your inbox to confirm.";
            msg.className = "mt-2 text-sm text-green-600 dark:text-green-400";
            email.value = "";
            btn.removeAttribute("disabled");
            btn.textContent = "Subscribe";
            trackSignup();
          }

          try {
            const res = await fetch(form.action, {
              method: "POST",
              body: new FormData(form),
            });

            if (res.ok) {
              showSuccess();
              return;
            }
          } catch {
            // CORS or network error — fall through to native POST
          }

          // Native POST fallback (new tab) — handles verification steps
          btn.removeAttribute("disabled");
          btn.textContent = "Subscribe";
          trackSignup();
          form.target = "_blank";
          form.submit();
          form.removeAttribute("target");
          email.value = "";
          msg.textContent = "Complete signup in the new tab.";
          msg.className = "mt-2 text-sm text-foreground opacity-80";
        });
      });
  }

  // Re-attach on every navigation (View Transitions support)
  document.addEventListener("astro:page-load", initNewsletterForms);
</script>
