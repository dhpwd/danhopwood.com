---
import { SHARE_LINKS } from "@/constants";
import LinkButton from "./LinkButton.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageUrl = Astro.url.href;
---

{
  SHARE_LINKS.length > 0 && (
    <div class="flex flex-none flex-col items-center justify-center gap-1 md:items-start">
      <span class="italic">Share this post on:</span>
      <div class="text-center md:-ml-2">
        {SHARE_LINKS.map(social => (
          <LinkButton
            href={social.buildHref(pageUrl, title)}
            class="p-3 hover:rotate-6 sm:p-2"
            title={social.linkTitle}
            target="_blank"
            rel="noopener noreferrer"
            data-share={social.name}
          >
            <social.icon class="inline-block size-8 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:size-6" />
            <span class="sr-only">{social.linkTitle}</span>
          </LinkButton>
        ))}
      </div>
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLAnchorElement>("[data-share]").forEach(link => {
    link.addEventListener("click", () => {
      if (typeof window.plausible === "function") {
        window.plausible("Share Link", {
          props: { platform: link.dataset.share },
        });
      }
    });
  });
</script>
